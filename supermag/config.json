{
  "common": {
    "output_dir": "supermag-data"
  },
  "inventory": {
    "delay": 0.0,
    "timeout": 5,
    "retry": 3,
    "geo_location_change_threshold": 0.0001,
    "base_url": "https://supermag.jhuapl.edu/lib/services/inventory.php",
    "station_info_url": "https://supermag.jhuapl.edu/lib/services/?service=stations&fmt=json",
    "station_info_url_desc": "https://supermag.jhuapl.edu/line/?tab=stationinfo"
  },
  "data": {
    "timeout": 60,
    "retry": 3,
    "formats": ["json", "list", "dataframe", "csv", "csv-hapi", "csv-hapi-noheader"],
    "cadences": ["PT1M"],
    "mag": {
      "baselines": ["yearly", "all", "none"],
      "deltas": ["start", "none"],
      "extra_request_parameters_comment": "We always request all extra parameters for mag data requests. Note: mlt => response includes mlt, and mcolat. All others are single.",
      "extra_request_parameters": ["mlt", "geo", "decl", "sza"],
      "known_response_parameters": ["tval", "ext", "iaga", "glon", "glat", "mlt", "mcolat", "decl", "sza", "N", "E", "Z"],
      "request_response_parameter_map": {
        "mlt": ["mlt", "mcolat"],
        "geo": ["glat", "glon"]
      }
    },
    "base_url": {
      "indices": "https://supermag.jhuapl.edu/services/indices.php?python&nohead",
      "data": "https://supermag.jhuapl.edu/services/data-api.php?python&nohead"
    }
  }
}